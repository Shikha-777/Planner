#!/usr/bin/env bash
# Run tau-bench with the direct goal-graph runtime agent on Compute1/LSF.
# This intentionally bypasses tau_ensemble_agent.py.
#BSUB -J tau_goal_graph
#BSUB -q general
#BSUB -g /dshrestha/taskdecomp
#BSUB -G compute-yvorobeychik
#BSUB -n 8
#BSUB -M 64GB
#BSUB -R "select[gpuhost && hname!='compute1-exec-401' && hname!='compute1-exec-208'] rusage[mem=64GB]"
#BSUB -gpu "num=1:j_exclusive=yes"
#BSUB -W 02:00
#BSUB -oo /storage3/fs1/yvorobeychik/Active/dshrestha/taskdecomp-gpt-oss/logs/compute1/tau_goal_graph.%J.out
#BSUB -eo /storage3/fs1/yvorobeychik/Active/dshrestha/taskdecomp-gpt-oss/logs/compute1/tau_goal_graph.%J.err
#BSUB -a "docker(pytorch/pytorch:2.6.0-cuda12.4-cudnn9-devel)"

set -euo pipefail

export STOR="${STOR:-/storage3/fs1/yvorobeychik/Active/dshrestha}"
export PROJ="${PROJ:-$STOR/taskdecomp-gpt-oss}"
export WF="${WF:-$STOR/workflow}"
export BR="${BR:-$PROJ/results}"
if [[ -z "${TAU_BENCH_DIR:-}" ]]; then
  if [[ -f "$PROJ/external/tau-bench/setup.py" ]]; then
    export TAU_BENCH_DIR="$PROJ/external/tau-bench"
  else
    export TAU_BENCH_DIR="$WF/external/tau-bench"
  fi
fi

cd "$PROJ"
mkdir -p "$BR" logs/compute1 "$PROJ/tmp-c1" \
  "$PROJ/.home-c1" "$PROJ/.cache-c1" "$PROJ/.hf_cache"

export HOME="$PROJ/.home-c1"
export XDG_CACHE_HOME="$PROJ/.cache-c1"
export HF_HOME="$PROJ/.hf_cache"
export HUGGINGFACE_HUB_CACHE="$HF_HOME/hub"
export TRANSFORMERS_CACHE="$HF_HOME/transformers"
export HF_DATASETS_CACHE="$HF_HOME/datasets"
export PIP_CACHE_DIR="$XDG_CACHE_HOME/pip"
export TMPDIR="$PROJ/tmp-c1"
export PYTHONNOUSERSITE=1
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export CC="${CC:-gcc}"
export PYTHONPATH="$PROJ/src:$PROJ/scripts:$PROJ/compute2:$WF/scripts:$TAU_BENCH_DIR:${PYTHONPATH:-}"
find "$PROJ/compute2" -path '*/__pycache__/tau_goal_graph_agent*.pyc' -delete 2>/dev/null || true

PYTHON_BIN=/opt/conda/bin/python VENV_DIR=.venv-c1 \
  bash scripts/bootstrap_env.sh >"logs/compute1/${LSB_JOBID:-manual}.tau_goal_graph_bootstrap.log" 2>&1

source "$PROJ/.venv-c1/bin/activate"
python -m pip install -q \
  "litellm>=1.41.0" \
  "openai>=1.13.3" \
  "pydantic>=2" \
  "termcolor>=2.4.0" \
  "tenacity>=8.3.0" \
  "anthropic>=0.26.1" \
  "mistralai>=0.4.0" \
  "google-generativeai>=0.5.4"
python -m pip install -q -e "$TAU_BENCH_DIR"

hostname
nvidia-smi
python - <<'PY'
import torch
print("torch", torch.__version__, "cuda", torch.version.cuda, "available", torch.cuda.is_available(), "count", torch.cuda.device_count())
if torch.cuda.is_available():
    props = torch.cuda.get_device_properties(0)
    print("device0", torch.cuda.get_device_name(0), torch.cuda.get_device_capability(0), round(props.total_memory / 1024**3, 2), "GB")
PY

JOB_ID="${LSB_JOBID:-manual}"
USER_MODEL="${USER_MODEL:-qwen2.5:14b}"
USER_MODEL_PROVIDER="${USER_MODEL_PROVIDER:-ollama_chat}"
USER_STRATEGY="${USER_STRATEGY:-llm}"

echo "CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-unset}"
echo "User simulator provider=$USER_MODEL_PROVIDER model=$USER_MODEL strategy=$USER_STRATEGY"

if [[ "$USER_MODEL_PROVIDER" == "ollama_chat" || "$USER_MODEL_PROVIDER" == "ollama" ]]; then
  PORT="${OLLAMA_PORT:-$((23000 + (JOB_ID % 10000)))}"
  export OLLAMA_HOST="127.0.0.1:$PORT"
  export OLLAMA_API_BASE="http://127.0.0.1:$PORT"
  export OLLAMA_MODELS="${OLLAMA_MODELS:-$STOR/ollama}"
  export OLLAMA_KEEP_ALIVE="${OLLAMA_KEEP_ALIVE:-30s}"
  export OLLAMA_NUM_PARALLEL="${OLLAMA_NUM_PARALLEL:-1}"
  export OLLAMA_MAX_LOADED_MODELS="${OLLAMA_MAX_LOADED_MODELS:-1}"

  OLLAMA_BIN="${OLLAMA_BIN:-$STOR/bin/ollama}"
  if [[ ! -x "$OLLAMA_BIN" ]]; then
    OLLAMA_BIN="$(command -v ollama)"
  fi

  echo "Starting Ollama on port=$PORT"
  "$OLLAMA_BIN" serve >"$PROJ/logs/compute1/${JOB_ID}.tau_goal_graph_ollama.log" 2>&1 &
  OLLAMA_PID=$!
  trap 'kill "$OLLAMA_PID" 2>/dev/null || true' EXIT

  for i in $(seq 1 90); do
    if "$OLLAMA_BIN" list >/dev/null 2>&1; then
      echo "Ollama ready after $((i * 2))s"
      break
    fi
    if ! kill -0 "$OLLAMA_PID" 2>/dev/null; then
      echo "Ollama exited before readiness" >&2
      tail -80 "$PROJ/logs/compute1/${JOB_ID}.tau_goal_graph_ollama.log" >&2 || true
      exit 1
    fi
    sleep 2
  done

  if [[ "${SKIP_OLLAMA_PULL:-1}" != "1" ]]; then
    "$OLLAMA_BIN" pull "$USER_MODEL"
  else
    echo "Skipping Ollama pull for $USER_MODEL (set SKIP_OLLAMA_PULL=0 to pull)"
  fi
else
  trap - EXIT
fi

export TAU_GOAL_GRAPH_MODEL="${TAU_GOAL_GRAPH_MODEL:-openai/gpt-oss-20b}"
export TAU_GOAL_GRAPH_MAX_NEW_TOKENS="${TAU_GOAL_GRAPH_MAX_NEW_TOKENS:-900}"
export TAU_GOAL_GRAPH_REPAIR_ATTEMPTS="${TAU_GOAL_GRAPH_REPAIR_ATTEMPTS:-1}"
export TAU_GOAL_GRAPH_MAX_STEPS="${TAU_GOAL_GRAPH_MAX_STEPS:-30}"
export TAU_GOAL_GRAPH_PLANNER_MODE="${TAU_GOAL_GRAPH_PLANNER_MODE:-stepwise}"
export TAU_GOAL_GRAPH_ALLOW_SIDE_EFFECTS="${TAU_GOAL_GRAPH_ALLOW_SIDE_EFFECTS:-1}"
export TAU_GOAL_GRAPH_DEBUG_DIR="${TAU_GOAL_GRAPH_DEBUG_DIR:-$BR/tau_goal_graph_c1_debug_${JOB_ID}}"

SPLIT="${SPLIT:-dev}"
START="${START:-0}"
END="${END:-2}"
TASK_IDS="${TASK_IDS:-}"
TRIALS="${TRIALS:-1}"
TAU_ENV="${TAU_ENV:-retail}"
if [[ -n "$TASK_IDS" ]]; then
  TASK_LABEL="$(echo "$TASK_IDS" | tr '[:space:],:' '____' | tr -s '_' | sed 's/^_//;s/_$//')"
  LOG_DIR="${LOG_DIR:-$BR/tau_goal_graph_c1_${TAU_ENV}_${SPLIT}_ids_${TASK_LABEL}_${JOB_ID}}"
else
  LOG_DIR="${LOG_DIR:-$BR/tau_goal_graph_c1_${TAU_ENV}_${SPLIT}_${START}_${END}_${JOB_ID}}"
fi

echo "Running tau goal-graph on Compute1: env=$TAU_ENV split=$SPLIT start=$START end=$END task_ids=${TASK_IDS:-none} trials=$TRIALS"
echo "Goal-graph model=$TAU_GOAL_GRAPH_MODEL planner=$TAU_GOAL_GRAPH_PLANNER_MODE"
echo "Tau-bench dir=$TAU_BENCH_DIR"
echo "Logs/results: $LOG_DIR"

RUN_ARGS=(
  --agent-strategy goal-graph
  --env "$TAU_ENV"
  --model "$TAU_GOAL_GRAPH_MODEL"
  --model-provider openai
  --user-model "$USER_MODEL"
  --user-model-provider "$USER_MODEL_PROVIDER"
  --user-strategy "$USER_STRATEGY"
  --task-split "$SPLIT"
  --num-trials "$TRIALS"
  --max-concurrency 1
  --temperature "${TEMPERATURE:-0}"
  --log-dir "$LOG_DIR"
)
if [[ -n "$TASK_IDS" ]]; then
  read -r -a TASK_ID_ARGS <<< "$TASK_IDS"
  RUN_ARGS+=(--task-ids "${TASK_ID_ARGS[@]}")
else
  RUN_ARGS+=(--start-index "$START" --end-index "$END")
fi

cd "$TAU_BENCH_DIR"
python "$PROJ/compute2/tau_run.py" "${RUN_ARGS[@]}"
